---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-white text-slate-800 min-h-screen font-sans selection:bg-blue-100 selection:text-blue-900 flex flex-col">
    
    <div class="max-w-4xl mx-auto px-6 py-12 flex-grow w-full">
      <Header />

      <div class="markdown-body">
        <slot />
      </div>
    </div>

    <Footer />

  </body>
</html>